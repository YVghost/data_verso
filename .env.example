# true  → Docker  (SQL Auth, localhost:1434)
# false → local   (Windows Auth, SQL Server instalado)
DV_USE_DOCKER=true

DV_SERVER=localhost
DV_DATABASE=data_verso
DV_PORT=1434

DV_ADMIN_USER=dv_admin
DV_ADMIN_PASSWORD=Admin_Strong_Pass1!
DV_READ_USER=dv_reader
DV_READ_PASSWORD=Reader_Strong_Pass1!

# Solo para docker compose — no lo usan los loaders ETL
MSSQL_SA_PASSWORD=SA_Strong_Pass1!
